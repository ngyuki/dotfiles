{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "Default"
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "tools": {
    "allowed": [
      "run_shell_command(ls)",
      "run_shell_command(grep)",
      "run_shell_command(git status)",
      "run_shell_command(gh issue view)",
      "web_fetch"
    ]
  },
  "mcpServers": {
    "aws-knowledge-mcp-server": {
      "httpUrl": "https://knowledge-mcp.global.api.aws"
    }
  }
}
